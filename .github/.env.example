# =============================================================
# .env.example — FreeRADIUS Adaptive Stack
# Copy to .env before first run. Never commit .env to git.
# All CHANGE_ME values MUST be replaced before any deployment.
#
# Generate strong secrets with: openssl rand -base64 32
# =============================================================

# ---- General ------------------------------------------------
TZ=UTC
DEBUG=false

# ---- RADIUS ports -------------------------------------------
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ---- RADIUS secrets -----------------------------------------
# SECURITY: These must match what is configured on each NAS/AP.
# Use a unique secret per NAS where possible (see clients.conf).
# Minimum 22 random bytes. Never reuse across environments.
RADIUS_SECRET=CHANGE_ME_use_openssl_rand_base64_32
RADIUS_HEALTH_SECRET=CHANGE_ME_health_secret

# ---- FreeRADIUS scaling -------------------------------------
# Tier B:  RADIUS_REPLICAS=1  (no ha profile needed)
# Tier C:  RADIUS_REPLICAS=2  (requires --profile ha)
# Rule: RADIUS_REPLICAS > 1 requires ha profile + HAProxy.
RADIUS_REPLICAS=1

# Worker threads per replica.
# Tier B:  8  (suitable for 4-vCPU host)
# Tier C:  16 (suitable for 8-vCPU host)
# Rule: num_workers = vCPU × 2 when DB latency is a factor.
RADIUS_WORKERS=8

# ---- PostgreSQL ---------------------------------------------
POSTGRES_DB=radius
POSTGRES_USER=radius
# SECURITY: Change this. openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_db_password

# Postgres tuning
# Tier B:  PG_MAX_CONNECTIONS=100  PG_SHARED_BUFFERS=256MB
# Tier C:  PG_MAX_CONNECTIONS=200  PG_SHARED_BUFFERS=512MB
# PG_EFFECTIVE_CACHE: ~75% of total host RAM
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=4MB
PG_EFFECTIVE_CACHE=1GB

# ---- pgBouncer ----------------------------------------------
# transaction mode is REQUIRED for FreeRADIUS multi-threaded use.
PGBOUNCER_POOL_MODE=transaction

# Tier B:  MAX_CLIENT_CONN=100  DEFAULT_POOL_SIZE=15
# Tier C:  MAX_CLIENT_CONN=200  DEFAULT_POOL_SIZE=25
# Rule: MAX_CLIENT_CONN >= RADIUS_REPLICAS × RADIUS_WORKERS
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=15
PGBOUNCER_MIN_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_SIZE=5

# ---- Redis (profile: cache) ---------------------------------
REDIS_PORT=6379
# SECURITY: Change this. openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_redis_password
# 128mb = Tier B+,  256mb = Tier C
REDIS_MAXMEMORY=256mb
# TTL in seconds. Align to your provisioning SLA.
# 300 = fast revocation. 3600 = higher hit rate, slower revocation.
RADIUS_CACHE_TTL=300

# ---- Network ------------------------------------------------
RADIUS_NET_SUBNET=172.28.0.0/16

# ---- Testing (profile: testing) ----------------------------
# Set to 'haproxy' when ha profile is active.
RADIUS_TEST_HOST=freeradius

# ---- GitHub Actions (set as Secrets in GitHub, not here) ---
# SSH_PRIVATE_KEY, SSH_HOST, SSH_USER
# POSTGRES_PASSWORD, REDIS_PASSWORD
# RADIUS_SECRET, RADIUS_HEALTH_SECRET
# Set as Variables (not Secrets): DEPLOY_PATH, RADIUS_REPLICAS
