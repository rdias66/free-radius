sql {
    dialect  = "postgresql"
    driver   = "rlm_sql_postgresql"

    # Connection parameters resolved from local.conf (generated by entrypoint-local.sh).
    # FreeRADIUS expands ${var} from the config namespace at parse time — this works.
    # %{env:VAR} does NOT work at instantiation time (only during request processing).
    server    = "${sql_server}"
    port      = "${sql_port}"
    login     = "${sql_login}"
    password  = "${sql_password}"
    radius_db = "${sql_db}"

    pool {
        start        = 5
        min          = 5
        max          = 20
        spare        = 5
        uses         = 0
        retry_delay  = 30
        lifetime     = 0
        idle_timeout = 60
    }

    acct_table1        = "radacct"
    acct_table2        = "radacct"
    postauth_table     = "radpostauth"
    authcheck_table    = "radcheck"
    authreply_table    = "radreply"
    groupcheck_table   = "radgroupcheck"
    groupreply_table   = "radgroupreply"
    usergroup_table    = "radusergroup"

    client_table    = "nas"
    group_attribute = "SQL-Group"

    read_clients = no
    read_groups  = yes

    safe_characters = "@abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.-_: /"

    $INCLUDE ${modconfdir}/${.:name}/main/${dialect}/queries.conf

    # Override postauth_query to also capture Calling-Station-Id (MAC address).
    # The default query from the image omits this column; we need it so that
    # v_connection_log can show the subscriber MAC on both accept and reject events.
    postauth_query = "\
        INSERT INTO ${postauth_table} \
            (username, pass, reply, authdate, callingstationid) \
        VALUES( \
            '%{SQL-User-Name}', \
            '%{%{User-Password}:-Chap-Password}', \
            '%{reply:Packet-Type}', \
            '%S', \
            '%{Calling-Station-Id}')"
}
